# ============================================
# PAM 特权账号管理系统 - 环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# === 数据库配置 ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<你的MySQL数据库密码>
DB_NAME=pam_system

# === 主密钥（SM4工作密钥的加密密钥）===
# 生成方式: python -c "import secrets; print(secrets.token_hex(16))"
MASTER_KEY=<32位十六进制随机字符串>

# === JWT配置 ===
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<64位十六进制随机字符串>

# === SM2私钥（可选，用于签名验签）===
# 方式一：明文私钥（开发环境）
# SM2_PRIVATE_KEY=<SM2私钥十六进制字符串>
# 方式二：加密私钥（生产推荐）
# SM2_PRIVATE_KEY_ENCRYPTED=false
# SM2_PRIVATE_KEY_ENCRYPTED_DATA=<PBKDF2加密后的私钥数据>
# SM2_PRIVATE_KEY_PASSWORD=<解密密码>

# === MySQL代理配置 ===
MYSQL_PROXY_TARGET_HOST=localhost
MYSQL_PROXY_TARGET_PORT=3306
MYSQL_PROXY_TARGET_PASSWORD=<MySQL代理连接密码>

# === 系统密钥链（可选，用于存储主密钥）===
# KEYRING_BACKEND=cryptfile
